# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_PRO=gemini-2.5-flash
GEMINI_MODEL_FLASH=gemini-2.5-flash

# Security — leave API_KEY empty to disable auth (development only)
API_KEY=

# CORS — comma-separated list of allowed origins, or * for any (development only)
# Example: CORS_ORIGINS=http://localhost:3000,http://10.0.2.2:8000
CORS_ORIGINS=*

# Server
HOST=0.0.0.0
PORT=8000

# Offline mode — set to true to use cached fixtures instead of live Gemini calls
OFFLINE_MODE=false
